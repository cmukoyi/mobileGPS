#!/bin/bash
# Pre-commit hook to prevent accidentally committing localhost URLs
# 
# Install: Run this from repo root:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit

echo "🔍 Checking for localhost URLs in Flutter code..."

# Check for localhost URLs in Dart files
FORBIDDEN_PATTERNS=(
  "localhost:8000"
  "localhost:3000"
  "localhost:3001"
  "localhost:3002"
  "127.0.0.1:8000"
  "192.168"
  "10.0.0"
  "http://localhost"
)

STAGED_DART_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.dart$")

if [ -z "$STAGED_DART_FILES" ]; then
  exit 0
fi

# Exclude environment.dart since it's designed to contain both localhost and production URLs
STAGED_DART_FILES=$(echo "$STAGED_DART_FILES" | grep -v "config/environment.dart")

if [ -z "$STAGED_DART_FILES" ]; then
  echo "✅ Only environment.dart changed - allowed"
  exit 0
fi

FAILED=0

for PATTERN in "${FORBIDDEN_PATTERNS[@]}"; do
  if echo "$STAGED_DART_FILES" | xargs grep -n "$PATTERN" 2>/dev/null; then
    echo ""
    echo "❌ ERROR: Found localhost/development URL: $PATTERN"
    echo "   Development URLs should NEVER be committed to main branch!"
    echo ""
    echo "   Solutions:"
    echo "   1. Use Environment.apiBaseUrl from lib/config/environment.dart"
    echo "   2. For local dev: flutter run --dart-define=ENV=dev"
    echo "   3. Production URLs are safe to commit"
    echo ""
    FAILED=1
  fi
done

if [ $FAILED -eq 1 ]; then
  echo "🚫 Pre-commit check FAILED. Fix the issues above."
  exit 1
fi

echo "✅ Pre-commit check passed - No localhost URLs found"
exit 0

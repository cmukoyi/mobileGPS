# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# Application Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# Email Configuration
# Option 1: SendGrid (Recommended for Production - Free Tier: 100 emails/day)
SENDGRID_API_KEY=your-sendgrid-api-key-here
FROM_EMAIL=noreply@yourdomain.com

# Option 2: SMTP (Fallback or Development)
# If SENDGRID_API_KEY is not set, SMTP will be used
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True

# MZone API Configuration
MZONE_BASE_URL=https://api.mzoneweb.net
MZONE_CLIENT_ID=your-mzone-client-id
MZONE_CLIENT_SECRET=your-mzone-client-secret
MZONE_TOKEN_URL=https://login.mzoneweb.net/connect/token
MZONE_API_TIMEOUT=30

# MProfiler API Configuration
MPROFILER_BASE_URL=https://live.scopemp.net/Scope.MProfiler.Api
MPROFILER_USERNAME=your-mprofiler-username
MPROFILER_PASSWORD=your-mprofiler-password

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5001
